generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  password      String?
  image         String?
  role          String    @default("USER") // USER | ADMIN
  xp            Int       @default(0)
  streak        Int       @default(0)
  lastActiveAt  DateTime  @default(now())
  createdAt     DateTime  @default(now())

  accounts      Account[]
  sessions      Session[]
  progress      UserProgress[]
  lessonHistory LessonHistory[]
  examResults   ExamResult[]
  savedVocab    SavedVocab[]
}

model Vocabulary {
  id        String   @id @default(cuid())
  hanzi     String
  pinyin    String
  meaning   String
  hskLevel  Int
  audioUrl  String?
  examples  Json     @default("[]")
  tags      String[]
  createdAt DateTime @default(now())

  userProgress UserProgress[]
}

model GrammarLesson {
  id        String   @id @default(cuid())
  title     String
  titleVi   String
  hskLevel  Int
  content   Json     @default("[]")
  exercises Json     @default("[]")
  order     Int
  createdAt DateTime @default(now())

  userProgress UserProgress[]
}

model LessonHistory {
  id          String     @id @default(cuid())
  userId      String
  type        LessonType
  title       String
  content     Json       @default("{}")
  score       Int?
  xpEarned    Int        @default(0)
  completedAt DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, completedAt])
}

model UserProgress {
  id           String    @id @default(cuid())
  userId       String
  vocabularyId String?
  lessonId     String?
  masteryLevel Int       @default(0)
  nextReviewAt DateTime  @default(now())
  reviewCount  Int       @default(0)
  updatedAt    DateTime  @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocabulary    Vocabulary?    @relation(fields: [vocabularyId], references: [id])
  grammarLesson GrammarLesson? @relation(fields: [lessonId], references: [id])

  @@unique([userId, vocabularyId])
  @@unique([userId, lessonId])
}

model ExamResult {
  id       String   @id @default(cuid())
  userId   String
  examType String
  score    Int
  maxScore Int
  details  Json     @default("{}")
  takenAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, takenAt])
}

model ReadingPassage {
  id          String   @id @default(cuid())
  title       String
  titleVi     String
  hskLevel    Int
  content     String   @db.Text   // Chinese text
  pinyin      String   @db.Text
  translation String   @db.Text   // Vietnamese translation
  vocabulary  Json     @default("[]") // [{hanzi, pinyin, meaning}]
  questions   Json     @default("[]") // [{question, options[], answer, explanation}]
  tags        String[]
  difficulty  String   @default("medium") // easy, medium, hard
  wordCount   Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([hskLevel, published])
}

model SavedVocab {
  id        String   @id @default(cuid())
  userId    String
  hanzi     String
  pinyin    String
  meaning   String
  source    String?  // "reading:passage-id"
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, hanzi])
  @@index([userId])
}

enum LessonType {
  VOCABULARY
  GRAMMAR
  LISTENING
  SPEAKING
  READING
  WRITING
  EXAM
}
